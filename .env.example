RESEND_API_KEY=re_xxxxxxxxxxxx       # Hämta på resend.com (gratis, 100 mail/dag)
FROM_EMAIL=noreply@dindomän.se       # Valfri — default: noreply@varfinnsdet.se
SITE_NAME=varfinnsdet.se             # Valfri — sajt-namn i mallar och e-post
SITE_URL=http://localhost:5000       # Publik URL utan avslutande /, används i länkar/e-post
POLL_INTERVAL=2                      # minuter mellan kontroller
DB_PATH=/data/medicinstatus.db       # Valfri — sökväg till SQLite-databasen
CACHE_FILE=/data/medicinstatus_cache.json  # Valfri — sökväg för tillstånds-cache
DAILY_MAIL_LIMIT=90                  # Valfri — max antal mejl/dygn mot Resend-gränsen
NOTIFICATIONS_PAUSED=true            # Valfri — stänger av bevaknings-mejl helt (default: true just nu, tillfälligt)
